<!DOCTYPE html><!-- Last Published: Mon Jan 05 2026 18:02:49 GMT+0000 (Coordinated Universal Time) --><html data-wf-domain="www.getfliff.com" data-wf-page="666cd94d9632b8cca00a9d03" data-wf-site="666cd94d9632b8cca00a9c98" lang="en"><head><meta charset="utf-8"/><title>Not Found</title><meta content="Not Found" property="og:title"/><meta content="Not Found" property="twitter:title"/><meta content="width=device-width, initial-scale=1" name="viewport"/><link href="https://cdn.prod.website-files.com/666cd94d9632b8cca00a9c98/css/fliff-web.shared.24340b0b5.css" rel="stylesheet" type="text/css"/><script type="text/javascript">!function(o,c){var n=c.documentElement,t=" w-mod-";n.className+=t+"js",("ontouchstart"in o||o.DocumentTouch&&c instanceof DocumentTouch)&&(n.className+=t+"touch")}(window,document);</script><link href="https://cdn.prod.website-files.com/666cd94d9632b8cca00a9c98/66ad14878d4d1a84b4bfb10f_Favicon.webp" rel="shortcut icon" type="image/x-icon"/><link href="https://cdn.prod.website-files.com/666cd94d9632b8cca00a9c98/66ad150eb41fc1928f857d2e_Webclip%20(1)%20(1).png" rel="apple-touch-icon"/><script async="" src="https://www.googletagmanager.com/gtag/js?id=G-3SPLH8V78V"></script><script type="text/javascript">window.dataLayer = window.dataLayer || [];function gtag(){dataLayer.push(arguments);}gtag('set', 'developer_id.dZGVlNj', true);gtag('js', new Date());gtag('config', 'G-3SPLH8V78V');</script><script>
(function () {
  const isAppOpenedInWebView = () => navigator.userAgent?.toLowerCase().includes("fliff-native") || false;

  const createCloseButton = () => {
    const btn = document.createElement("button");
    btn.id = "close-webview";
    btn.textContent = "Go Back";

    Object.assign(btn.style, {
      position: "fixed",
      bottom: "20px",
      left: "20px",
      right: "20px",
      height: "50px",
      borderRadius: "10px",
      fontWeight: "bold",
      background: "linear-gradient(180deg, #1f35ff, #7e00ff)",
      borderBottom: "2px solid #8f9daf",
      cursor: "pointer",
      zIndex: "9999"
    });

    btn.addEventListener("click", () => {
      const steps = historyChangeCount + 1;
      history.go(-steps);
    });

    return btn;
  };

  // Track history changes
  let historyChangeCount = 0;

  const wrapHistoryMethod = (method) => {
    const original = history[method];
    history[method] = function (...args) {
      const result = original.apply(this, args);
      historyChangeCount++;
      return result;
    };
  };

  wrapHistoryMethod("pushState");
  wrapHistoryMethod("replaceState");

  window.addEventListener("popstate", () => {
    historyChangeCount++;
  });

  const initializeWebViewLogic = () => {
    if (!isAppOpenedInWebView()) return;

    const hamburger = document.querySelector(".c-nav_right");
    const footer = document.querySelector(".c-footer");
    if (hamburger) hamburger.style.display = "none";
    if (footer) footer.style.display = "none";

    document.body.appendChild(createCloseButton());
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeWebViewLogic);
  } else {
    initializeWebViewLogic();
  }
})();
</script>
