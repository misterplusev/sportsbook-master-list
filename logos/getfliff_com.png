  /* Texts blinking */
  [text-buzzing-toggle].cc-active {
    animation: buzzing 0.2s linear infinite;
  }

  [text-buzzing] {
    animation: buzzing 0.75s linear infinite;
  }

  @keyframes buzzing {
    0% { opacity: 1; }
    25% { opacity: 0.88; }
    50% { opacity: 0.92; }
    75% { opacity: 0.84; }
    100% { opacity: 1; }
  }

  [filter-wrapper]:has([filter-toggle]:hover) [filter-list-wrapper] {
    pointer-events: all;
  }

  [filter-list-wrapper]:hover {
    pointer-events: all;
  }

  [filter-wrapper]:hover .c-dropdown_arrow {
    transform: rotateZ(180deg);
  }

  [filter-wrapper]:has([filter-toggle]:hover) [filter-list], 
  [filter-list-wrapper]:hover [filter-list] {
    opacity: 1;
    transform: translateY(0);
  }

  [available] [is-available], [available] [no-available] {
    display: none;
  }

  [available="true"] [is-available] {
    display: flex;
  }

  [available="false"] [no-available] {
    display: flex;
  }

  [r-slide-tab][active] .c-superstars_slider-text-wrap {
    grid-template-rows: 1fr;
    padding-top: 0.5em;
    opacity: 1;
  }

  [hero-speed] {
    will-change: transform;
  }

  [r-slide-robot-face] {
    animation: faceMove 2s linear infinite;
  }

  [r-slide-robot-eyes-open] {
    animation: faceTiltHide 7s linear infinite;
  }

  [r-slide-robot-eyes-close] {
    animation: faceTiltShow 7s linear infinite;
  }

  @keyframes faceMove {
    0% {transform: translateY(-2.5px);}
    50% {transform: translateY(2.5px);}
    100% {transform: translateY(-2.5px);}
  }

  @keyframes faceTiltHide {
    /* Visible durante los primeros 5 segundos */
    0%, 50%, 56% {
      opacity: 1;
    }
    /* Parpadeo rápido entre 50% y 60% */
    57%, 63% {
      opacity: 0;
    }
    60%, 66% {
      opacity: 1;
    }
    /* Visible de nuevo hasta el final del ciclo */
    66%, 100% {
      opacity: 1;
    }
  }

  @keyframes faceTiltShow {
    /* Visible durante los primeros 5 segundos */
    0%, 50%, 56% {
      opacity: 0;
    }
    /* Parpadeo rápido entre 50% y 60% */
    57%, 63% {
      opacity: 1;
    }
    60%, 66% {
      opacity: 0;
    }
    /* Visible de nuevo hasta el final del ciclo */
    66%, 100% {
      opacity: 0;
    }
  }
