  }

  .c-toggle-phone::before {
    content: "";
    position: absolute;
    pointer-events: none;
    inset: 0;
    border-radius: 2.5em;
    border: 1px solid transparent;
    background: linear-gradient(0deg, rgba(100, 239, 253, 0.02) 25%, #FFA63C) border-box;
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    transition: background .3s ease;
  }

  .c-toggle-phone[green]::before {
    background: linear-gradient(0deg, rgba(100, 239, 253, 0.02) 25%, #61FE96) border-box;
  }

  .c-toggle-phone[green] .c-toggle-glow {
